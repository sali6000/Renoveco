            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="mShvxsyVHnVZXD5BHHtv-68" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Routes&lt;/h1&gt;&lt;p&gt;Contient toute les routes dynamiques du projet, permet d&#39;obtenir et construire facilement l&#39;aborescence du projet (ex: BASE_ENTREPRISE, BASE_PATH, BASE_URL)&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="-713" y="-377.37" width="230" height="120" as="geometry" />
        </mxCell>
        <mxCell id="mShvxsyVHnVZXD5BHHtv-72" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Composer.json&lt;/h1&gt;&lt;p&gt;Défini les dépendances, la configuration du projet PHP et les métadonnées nécessaires pour que Composer puisse installer et autoload les librairies correctement. Lorsqu’il inclut une section &lt;strong data-end=&quot;325&quot; data-start=&quot;299&quot;&gt;&lt;code data-end=&quot;311&quot; data-start=&quot;301&quot;&gt;autoload&lt;/code&gt; avec PSR-4`&lt;/strong&gt;, il permet de définir un mappage automatique entre les &lt;strong data-end=&quot;413&quot; data-start=&quot;381&quot;&gt;espaces de noms (namespaces)&lt;/strong&gt; et les &lt;strong data-end=&quot;444&quot; data-start=&quot;421&quot;&gt;chemins de dossiers&lt;/strong&gt;, facilitant le chargement des classes sans avoir à les inclure manuellement.&lt;br&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="80" y="-730" width="363" height="150" as="geometry" />
        </mxCell>
        <mxCell id="mShvxsyVHnVZXD5BHHtv-74" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Router&lt;/h1&gt;&lt;p&gt;Permet de définir en analysant l&#39;URL entré par l&#39;utilisateur, quel controler, quel action (méthode) et quel paramètres sont entrés afin d&#39;appeller en backend l&#39;action demandée&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="-710" y="170" width="180" height="170" as="geometry" />
        </mxCell>
