        <mxCell id="mShvxsyVHnVZXD5BHHtv-66" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Autoload&lt;/h1&gt;&lt;p&gt;Permet de charger et d&#39;inclure (&quot;require_once&quot;) automatiquement les fichiers solicités dans le projet sur base du composer.json (PSR-4)&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="-713" y="-510" width="230" height="120" as="geometry" />
        </mxCell>
        <mxCell id="mShvxsyVHnVZXD5BHHtv-67" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.019;entryY=0.163;entryDx=0;entryDy=0;entryPerimeter=0;exitX=1;exitY=0.75;exitDx=0;exitDy=0;" parent="1" source="mShvxsyVHnVZXD5BHHtv-63" target="mShvxsyVHnVZXD5BHHtv-46" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
