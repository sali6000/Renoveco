        <mxCell id="mShvxsyVHnVZXD5BHHtv-42" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;BaseDAO&lt;/h1&gt;&lt;p&gt;Permet de mettre à dispositions les différents queries (select, columns, innerJoin,...) formatées par le QueryBuilderInferface&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
