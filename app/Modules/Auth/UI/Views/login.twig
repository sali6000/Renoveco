{% extends "@Shared/UI/Views/layout/base.twig" %}

{% block title %}Connexion{% endblock %}

{% block content %}
    <section class="section-login">
        <div class="side-section"></div>
        {# Connection #}
        <section class="form-section reveal slide-up">
                <h2>Connectez-vous</h2>
                <form method="post" action="/auth/connection">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    {% if flash_error %}
                        <div class="alert alert-danger">{{ flash_error }}</div>
                    {% endif %}
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" placeholder="email@mail.com" maxlength="30" required autofocus class="form-control">
                    <br><br>
                    <label for="password">Mot de passe</label>
                    <input type="password" id="password" name="password" placeholder="password" maxlength="30" required class="form-control">
                    <br><br>
                    <button type="submit" class="btn btn-primary">Se connecter</button>
                </form>
                <form method="post" action="/auth/forgot-password">
                    <label for="email">Mot de passe oublié ? </label>
                    <input type="email" id="email" name="email" placeholder="email@mail.com" maxlength="30" required autofocus class="form-control">
                    <br><br>
                    <button type="submit" class="btn btn-primary">Envoyer sur la boite mail</button>
                </form>
        </section>
        <div class="side-section"></div>
    </section>
{% endblock %}