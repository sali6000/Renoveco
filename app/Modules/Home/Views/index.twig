{% extends "@Shared/layout/base.twig" %}

{% set current_page = 'home' %}

{% block title %}Accueil - {{ parent() }}{% endblock %}

{% block content %}

{# Début du slider #}
<section class="section__slides" id="slides-js" aria-label="Slider de présentation">
  {% for i in 1..3 %}
  <div class="slides__slide">
    <video autoplay muted loop playsinline preload="auto" width="100%">
      <source src="{{ encore_asset('webm/home/video' ~ i ~ '.webm') }}" type="video/webm" />
    </video>
    <div class="slides__slide__texts"> 
      {% if i == 1 %}
        <h2 class="reveal-infiny slide-up">Laissez vous guider <br>par nos experts. <br>Partouts en Belgique.</h2>
      {% elseif i == 2 %}
        <h2 class="reveal-infiny slide-up">Un service de qualité <br><b>sans engagements.</b></h2>
      {% else %}
        <h2 class="reveal-infiny slide-up">Des offres et des produits <br>défiants toutes concurrences.</h2>
      {% endif %}
      <a href="message">Contactez-nous</a>
      <br><br>
    </div>
  </div>
  {% endfor %}
  <div class="slides__style--arrow_left slides__event--prev"></div>
  <div class="slides__style--arrow_right slides__event--next"></div>
</section>
  {# Fin du slider #}

{# Début de présentation (1) #}
<section class="section__info__wrapper" aria-label="Arguments de vente">
  <h2 class="texte1">Économique - Écologique - Pratique</h2>
</section>
{# Fin de présentation (1) #}

{# Début de section catégories #}
<section class="section__info__wrapper reveal big-slide-right" aria-label="Catégories">
    <h2>Découvrez nos services</h2>
    <div class="categories">
    <a href="/devis">
      <img src="{{ encore_asset('img/home/image11.jpg') }}" alt="Établir un devis">
      <p>Établir un devis</p>
    </a>
    <a href="/installation">
      <img src="{{ encore_asset('img/home/image12.jpg') }}" alt="Installation">
      <p>Installation</p>
    </a>
    <a href="/catalogue">
      <img src="{{ encore_asset('img/home/image13.jpg') }}" alt="Catalogue">
      <p>Catalogue</p>
    </a>
    </div>
</section>
{# Fin de section catégories #}

{# Début de présentation (2) #}
<section class="section__info__wrapper" aria-label="Présentation de l'entreprise">
  <h2 class="texte2">L'experience Belge entre les mains des professionnels <b>depuis 20 ans</b></h2>
  <h3 class="texte3">Demandez une expertise <b>GRATUITEMENT</b></h3>
</section>
{# Fin de présentation (2) #}

{# Début de présentation (3) #}
<section class="section__info reveal slide-down" aria-label="Découverte de l'entreprise">
  <div class="about">
    <img src="{{ encore_asset('img/home/image14.jpg') }}" alt="ouvriers">
    <div class="description resizeText">
      <h2>Notre savoir faire:</h2> </br>
      <h3>
         loremlorem Lorem ipsum dolor sit amet consectetur adipisicing elit...loremlorem Lorem ipsum dolor sit amet consectetur adipisicing elit...loremlorem Lorem ipsum dolor sit amet consectetur adipisicing elit...loremlorem Lorem ipsum dolor sit amet consectetur adipisicing elit...loremlorem Lorem ipsum dolor sit amet consectetur adipisicing elit...loremlorem Lorem ipsum dolor sit amet consectetur adipisicing elit...loremlorem Lorem ipsum dolor sit amet consectetur adipisicing elit...
        (reste du texte ici)
      </h3>
    </div>
  </div>
</section>
