{% extends "layout.twig" %}
{% block title %}Historique des installations et réalisations{% endblock %}
{% block head %}
<script>
  loadCss("{{ base_url_assets_css ~ 'historyStylesheet.css' }}");

  document.addEventListener("DOMContentLoaded", function () {
    const cells = document.getElementsByClassName('cell border-bottom');
    if (cells.length > 2) {
      cells[2].style.borderBottom = "2px solid darkgrey";
    }
  });
</script>
{% endblock %}

{# Chargement du JS dédié à l’historique #}
{% block javascripts %}
<script src="{{ base_url_assets_js ~ 'history.js' }}"></script>
{% endblock %}

{# Contenu principal de la page #}
{% block content %}
<div class="container">
  <h1>Installations - Réalisations</h1>

  {% for year, achievements in datas %}
    <div class="year-section">
      <h2 class="year-title">{{ year }}</h2>

      <div class="achievements">
        {% for achievement in achievements %}
          <div class="achievement">
            <h3>{{ achievement.title }}</h3>
            <p>{{ achievement.story }}</p>

            <div class="images">
              {% for image in achievement.images %}
                <img src="{{ image }}" alt="{{ achievement.title }}">
              {% endfor %}
            </div>
          </div>
          <hr>
        {% endfor %}
      </div>
    </div>
  {% endfor %}
</div>
{% endblock %}
