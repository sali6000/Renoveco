{% extends "@Shared/layout/base.twig" %}
{% block title %}Devis - Contactez-nous{% endblock %}
{% block head %}
<script>
  loadCss("{{ base_url_assets_css ~ 'devisStylesheet.css' }}");

  document.addEventListener("DOMContentLoaded", function () {
    const cells = document.getElementsByClassName('cell border-bottom');
    if (cells.length > 3) {
      cells[3].style.borderBottom = "2px solid darkgrey";
    }
  });
</script>
{% endblock %}

{# Bloc CONTENU principal #}
{% block content %}
<div class="devis-join-section"><br><br>
  <h2>Envoyer un devis au format PDF par e-mail</h2>

  {# Étape 1 #}
  <div class="devis-join-presentation">
    <div class="devis-join-image">
      <img style="width:50%;" src="{{ encore_asset('img/layouts/emoticons/letter.png') }}" alt="letter">
    </div>
    <div class="devis-join-description">
      <h3>1. Laissez-nous vos coordonnées afin que l'on puisse prendre contact.</h3>
    </div>
  </div>

  {# Étape 2 #}
  <div class="devis-join-presentation">
    <div class="devis-join-image">
      <img style="width:50%;" src="{{ encore_asset('img/layouts/logos/pdf.png') }}" alt="pdf">
    </div>
    <div class="devis-join-description">
      <h3>2. Ajoutez un devis au format .PDF afin que nos collaborateurs s'en occupent.</h3>
    </div>
  </div>

  {# Étape 3 #}
  <div class="devis-join-presentation">
    <div class="devis-join-image">
      <img style="width:50%;" src="{{ encore_asset('img/layouts/emoticons/e-mail.png') }}" alt="e-mail-verifie">
    </div>
    <div class="devis-join-description">
      <h3>3. Envoyez la demande et nous vous répondrons dans les plus brefs délais.</h3>
    </div>
  </div>

  <h5 style="color:red;">Les champs marqués d'un astérisque (*) doivent obligatoirement être remplis.</h5>

  <form action="devis" name="uploadpdf" method="post" enctype="multipart/form-data">
    
    <label for="firstname">Nom:</label>
    <input type="text" id="firstname" name="firstname" maxlength="10" placeholder="LaPierre"><br><br>

    <label for="lastname">Prénom:</label>
    <input type="text" id="lastname" name="lastname" maxlength="10" placeholder="François"><br><br>

    <label for="email">* Adresse e-mail:</label>
    <input type="email" id="email" name="email" placeholder="***@mail.com" required><br><br>

    <label for="message">Communication (300 caractères max):</label><br>
    <textarea style="resize:none;" id="message" name="message" maxlength="300" rows="4" cols="50" placeholder="Bonjour, voici un message..."></textarea><br><br>

    <h4 id="fileSizeMax" style="display:none; color:red;"></h4>

    <label for="fichier">* Sélectionner un fichier PDF (<b><span style="color:red;">10 Mo max</span></b>):</label>
    <input type="file" id="fichier" name="fichier" accept=".pdf" onchange="Filevalidation()" required>
    
    <br><br><br>
    <button type="submit">Envoyer</button>
  </form>
</div>
{% endblock %}
