{% extends "@Admin/Shared/UI/Views/Layout/admin_base.twig" %}

{% block title %}Gestion des catégories{% endblock %}

{% block content %} {# ... {% endblock content %} #}
{{ block('admin_subnav') }}

{# superadmin => Categories => Afficher arborescence #}
<div class="section-admin-categories">
<div class="form-section">
        <h2>Ajouter une catégorie:</h2>
        {% if flash_error %}
            <div class="alert alert-danger">{{ flash_error }}</div>
        {% endif %}
        <form method="post" action="admin/category/addCategoryPost">
            <div class="form-group">
                <label for="name">Nom</label>
                <input type="text" id="name" name="name" placeholder="Vitrage en PVC" required autofocus class="form-control">
            </div><br>

            <div class="form-group">
                <label for="slug">Slug</label>
                <input type="text" id="slug" name="slug" placeholder="vitrage-en-pvc" required autofocus class="form-control">
            </div><br>

            <div class="form-group">
                <label for="description">Description</label>
                <input type="text" id="description" name="description" placeholder="Description de la catégorie" autofocus class="form-control">
            </div><br>
            
            <select name="parent_id">
                <option value="">-- Aucune catégorie sélectionné --</option>
                {% macro render_categories2(categories, index = '') %}
                    {% for category in categories %}
                        {% set new_index = index ~ loop.index %}
                        <option value="{{ category.id }}">{{ new_index }}. {{ category.name }}</option>
                        {% if category.children is defined and category.children|length > 0 %}
                            {{ _self.render_categories2(category.children, new_index ~ '.') }}
                        {% endif %}
                    {% endfor %}
                {% endmacro %}
                {{ _self.render_categories2(categories) }}
            </select>
            <button type="submit" class="btn btn-primary">Ajouter</button>
        </form>
    </div>
    <div class="form-section">
        <h2>Catégories déjà présentes:</h2>
        {% macro render_categories(categories, index = '', depth = 0) %}
            {% for category in categories %}
                {% set new_index = index ~ loop.index %}
                <p style="padding-left: {{ depth * 15 }}px;">
                    {{ new_index }}. {{ category.name }}
                </p>
                {% if category.children is defined and category.children|length > 0 %}
                    {{ _self.render_categories(category.children, new_index ~ '.', depth + 1) }}
                {% endif %}
            {% endfor %}
        {% endmacro %}
        {{ _self.render_categories(categories) }}
    </div>
</div>

{% if userSession.role is same as('superadmin') %}
{# superadmin => Categories => CRUD #}
<div class="section-row reveal slide-down">
        <h2>Gestion avancée des catégories:</h2><br><br>
    <table id="category-table" border="1" style="width:100%; border-collapse: collapse;">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nom</th>
                <th>Slug</th>
                <th>Description</th>
                <th>Parent ID</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <!-- Les lignes seront ajoutées par manageBoard.js -->
        </tbody>
    </table>
    </div>
{% endif %}
{% endblock content %}