{% extends "@Shared/layout/base.twig" %}

{% block title %}Contact - {{ parent() }}{% endblock %}

{% block content %}
<form action="contact/mailSend" name="uploadpdf" method="post" enctype="multipart/form-data">
  <h2>Envoyer un message</h2>
  <label for="firstname">Nom:</label>
  <input type="text" id="firstname" name="firstname" maxlength="10" placeholder="LaPierre"
  <label for="lastname">Prénom:</label>
  <input type="text" id="lastname" name="lastname" maxlength="10" placeholder="François"
  <label for="company">Société:</label>
  <input type="text" id="company" name="company" maxlength="10" placeholder="Entreprise"
  <label for="email">* Adresse e-mail:</label>
  <input type="email" id="email" name="email" placeholder="***@mail.com" required
  <label for="message">Communication (300 caractères max):</label>
  <textarea style="resize:none;" id="message" name="message" placeholder="Bonjour, voici un message..." maxlength="300" rows="4" cols="50"></textarea>
  <h5 style="color:red;">Les champs marqués d'un astérisque (*) doivent obligatoirement être remplis.</h5>
  <button type="submit" class="btn btn-primary">Envoyer</button>
</form>
{% endblock %}
